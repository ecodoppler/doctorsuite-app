{
  "expo": {
    "name": "doctorsuite-app",
    "slug": "doctorsuite-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "doctorsuiteapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "deploymentTarget": "16.0",
      "bundleIdentifier": "app.doctorsuite.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "DoctorSuite precisa da câmera para registrar selfie no ponto eletrônico (compliance Portaria 671/2021).",
          "photosPermission": "DoctorSuite precisa de acesso às fotos para selecionar imagens no chat.",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DoctorSuite usa a localização ao registrar ponto eletrônico para validar o geofencing (compliance Portaria 671/2021).",
          "locationAlwaysAndWhenInUsePermission": "DoctorSuite usa a localização ao registrar ponto eletrônico para validar o geofencing (compliance Portaria 671/2021)."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
